pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', 
                    credentialsId: 'github-token', 
                    url: 'https://github.com/ditiss2026/javarepo.git'
            }
        }

        stage('Compile') {
            steps {
                echo 'Compiling Java program...'
                sh 'java Hello.java'
            }
        }
	
	stage('Docker Build') {
            steps {
                echo 'Building Docker Image...'
                // Build the image and tag it as 'my-java-app'
                sh 'docker build -t my-java-app .'
            }
        }

        stage('Docker Run') {
            steps {
                echo 'Running Docker Container...'
                // --rm removes the container after it finishes running
                sh 'docker run --rm my-java-app'
            }
        }


      } // This closes the 'stages' block containing all 3 stages

    post {
        success {
            echo 'Pipeline executed successfully!'
        }
        failure {
            echo 'Something went wrong.'
        }
    }
}
