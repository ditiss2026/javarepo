pipeline {
    agent any

    environment {
        DOCKERHUB_USER = 'ditisscdac'
        APP_NAME = 'javarepo'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/ditiss2026/javarepo.git'
            }
        }

        stage('Compile') {
            steps {
                echo 'Compiling Java Source...'
                sh 'javac Hello.java'
            }
        }

        stage('Docker Build & Tag') {
            steps {
                echo 'Building and Tagging Image...'
                sh "docker build -t ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG} ."
                sh "docker tag ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG} ${DOCKERHUB_USER}/${APP_NAME}:latest"
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials',
                                                  passwordVariable: 'DOCKER_PASS',
                                                  usernameVariable: 'DOCKER_USER')]) {

                    echo 'Logging into DockerHub...'
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"

                    echo 'Pushing Image...'
                    sh "docker push ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG}"
                    sh "docker push ${DOCKERHUB_USER}/${APP_NAME}:latest"
                }
            }
        }
    }

    post {
        success {
            echo "Successfully pushed version ${IMAGE_TAG} to DockerHub!"
        }
        always {
            echo 'Cleaning up local environment...'
            // Clean up compiled class and local Docker images to keep the Jenkins node tidy
            sh "rm -f *.class"
            sh "docker rmi ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG} ${DOCKERHUB_USER}/${APP_NAME}:latestThe pipeline structure looks solid. You've correctly defined the environment variables and utilized the `withCredentials` block to securely handle your DockerHub token. 

Before you run this, ensure your `Dockerfile` has been updated to use the `eclipse-temurin` image as we discussed, otherwise, the **Docker Build** stage might still fail.

### Final Verification Checklist

1.  **Credentials ID:** Double-check that the ID in Jenkins is exactly `dockerhub-credentials`. If you named it something else (like `docker-login`), the pipeline will fail at the "Docker Push" stage.
2.  **Missing Closing Braces:** The snippet you provided is missing the `post` block and the final closing brace for the `pipeline`. Without these, you will get another "unexpected token" error.
3.  **Repository Visibility:** By default, your first push will create a **Public** repository on DockerHub.

---

### Complete & Polished Jenkinsfile
Here is the full, syntax-checked version including the `post` block for cleanup:
```groovy
pipeline {
    agent any

    environment {
        DOCKERHUB_USER = 'ditisscdac'
        APP_NAME = 'javarepo'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: '[https://github.com/ditiss2026/javarepo.git](https://github.com/ditiss2026/javarepo.git)'
            }
        }

        stage('Compile') {
            steps {
                echo 'Compiling Java Source...'
                sh 'javac Hello.java'
            }
        }

        stage('Docker Build & Tag') {
            steps {
                echo 'Building and Tagging Image...'
                sh "docker build -t ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG} ."
                sh "docker tag ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG} ${DOCKERHUB_USER}/${APP_NAME}:latest"
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials',
                                                  passwordVariable: 'DOCKER_PASS',
                                                  usernameVariable: 'DOCKER_USER')]) {

                    echo 'Logging into DockerHub...'
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"

                    echo 'Pushing Image...'
                    sh "docker push ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG}"
                    sh "docker push ${DOCKERHUB_USER}/${APP_NAME}:latest"
                }
            }
        }
    }

    post {
        success {
            echo "Successfully pushed version ${IMAGE_TAG} to DockerHub!"
        }
        always {
            echo 'Cleaning up local environment...'
            // Clean up compiled class and local Docker images to keep the Jenkins node tidy
            sh "rm -f *.class"
            sh "docker rmi ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG} ${DOCKERHUB_USER}/${APP_NAME}:latest || true"
        }
    }
}
