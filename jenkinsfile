pipeline {
    agent any

    environment {
        // Change this to your actual DockerHub username
        DOCKERHUB_USER = 'ditisscdac'
        APP_NAME = 'javarepo'
        IMAGE_TAG = "${env.BUILD_NUMBER}" // Uses build number for versioning
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/ditiss2026/javarepo.git'
            }
        }

        stage('Compile') {
            steps {
                sh 'javac Hello.java'
            }
        }

        stage('Docker Build & Tag') {
            steps {
                echo 'Building and Tagging Image...'
                // Build the image with the DockerHub naming convention
                sh "docker build -t ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG} ."
                // Also tag it as 'latest'
                sh "docker tag ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG} ${DOCKERHUB_USER}/${APP_NAME}:latest"
            }
        }

        stage('Docker Push') {
            steps {
                // Use the Credentials ID you created in Step 1
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials',
                                                  passwordVariable: 'DOCKER_PASS',
                                                  usernameVariable: 'DOCKER_USER')]) {

                    echo 'Logging into DockerHub...'
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"

                    echo 'Pushing Image...'
                    sh "docker push ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG}"
                    sh "docker push ${DOCKERHUB_USER}/${APP_NAME}:latest"
                }
            }
        }
    }

    post {
        always {
            echo 'Cleaning up local images...'
            // Optional: Remove local images to save disk space
            sh "docker rmi ${DOCKERHUB_USER}/${APP_NAME}:${IMAGE_TAG} || true"

